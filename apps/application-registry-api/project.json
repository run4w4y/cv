{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "application-registry-api",
  "projectType": "application",
  "sourceRoot": "apps/application-registry-api/src",
  "tags": ["scope:application-registry", "type:service", "visibility:private"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "color": true,
        "command": "bun build apps/application-registry-api/src/main.ts --target=bun --outdir=apps/application-registry-api/dist"
      }
    },
    "lint": {},
    "lint:fix": {},
    "format": {},
    "format:check": {},
    "test:unit": {},
    "test:integration": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["build"],
      "options": {
        "command": "node --import tsx --test --test-concurrency=1 apps/application-registry-api/test/application-registry.integration.test.ts apps/application-registry-api/test/s3-storage.integration.test.ts"
      }
    },
    "typecheck": {}
  }
}
