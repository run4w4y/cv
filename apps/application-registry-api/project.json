{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "application-registry-api",
  "projectType": "application",
  "sourceRoot": "apps/application-registry-api/src",
  "tags": ["scope:application-registry", "type:worker", "visibility:private"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "color": true,
        "command": "bun apps/application-registry-api/scripts/build.ts"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "outputs": [],
      "options": {
        "color": true,
        "commands": [
          "bun apps/application-registry-api/scripts/write-wrangler-config.ts apps/application-registry-api/wrangler.deploy.jsonc",
          "bun apps/application-registry-api/scripts/deploy.ts apps/application-registry-api/wrangler.deploy.jsonc"
        ],
        "parallel": false
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": [],
      "options": {
        "color": true,
        "command": "node node_modules/wrangler/bin/wrangler.js dev --config apps/application-registry-api/wrangler.jsonc"
      }
    },
    "migrations:apply:local": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "node node_modules/wrangler/bin/wrangler.js d1 migrations apply APPLICATION_REGISTRY_DB --local --config apps/application-registry-api/wrangler.jsonc"
      }
    },
    "migrations:apply:remote": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "commands": [
          "bun apps/application-registry-api/scripts/write-wrangler-config.ts apps/application-registry-api/wrangler.deploy.jsonc",
          "node node_modules/wrangler/bin/wrangler.js d1 migrations apply APPLICATION_REGISTRY_DB --remote --config apps/application-registry-api/wrangler.deploy.jsonc"
        ],
        "parallel": false
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "outputs": [],
      "options": {
        "color": true,
        "command": "node --import tsx --test apps/application-registry-api/test/application-registry.integration.test.ts"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "outputs": [],
      "options": {
        "color": true,
        "command": "node --import tsx --test apps/application-registry-api/test/application-registry.e2e.test.ts"
      }
    },
    "lint": {},
    "lint:fix": {},
    "test:unit": {},
    "typecheck": {},
    "format": {},
    "format:check": {}
  }
}
