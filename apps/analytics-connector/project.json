{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "analytics-connector",
  "projectType": "application",
  "sourceRoot": "apps/analytics-connector/src",
  "tags": ["scope:analytics", "type:worker", "visibility:private"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "color": true,
        "command": "bun build apps/analytics-connector/src/index.ts --target browser --outdir apps/analytics-connector/dist"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "outputs": [],
      "options": {
        "color": true,
        "commands": [
          "bun apps/analytics-connector/scripts/write-wrangler-config.ts apps/analytics-connector/wrangler.deploy.jsonc",
          "bunx wrangler deploy --config apps/analytics-connector/wrangler.deploy.jsonc"
        ],
        "parallel": false
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": [],
      "options": {
        "color": true,
        "command": "bunx wrangler dev --config apps/analytics-connector/wrangler.jsonc"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome check apps/analytics-connector"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome check --write apps/analytics-connector"
      }
    },
    "test": {
      "executor": "nx:noop",
      "dependsOn": [
        {
          "projects": "self",
          "target": "test:all"
        }
      ],
      "outputs": []
    },
    "test:all": {
      "executor": "nx:noop",
      "dependsOn": [
        {
          "projects": "self",
          "target": "test:unit"
        },
        {
          "projects": "self",
          "target": "typecheck"
        }
      ],
      "outputs": []
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/coverage"],
      "options": {
        "color": true,
        "command": "bun test --coverage",
        "cwd": "apps/analytics-connector"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "tsc --pretty --noEmit --project apps/analytics-connector/tsconfig.json",
        "cwd": "."
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome format --write apps/analytics-connector"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome format apps/analytics-connector"
      }
    }
  }
}
