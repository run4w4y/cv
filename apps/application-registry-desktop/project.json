{
  "name": "application-registry-desktop",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/application-registry-desktop/src",
  "projectType": "application",
  "implicitDependencies": ["application-registry-management"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "inputs": ["default", "^production"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "bun run scripts/build.ts",
        "cwd": "apps/application-registry-desktop"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["build"],
      "options": {
        "command": "bun run electron:run",
        "cwd": "apps/application-registry-desktop"
      }
    },
    "package:windows": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["build"],
      "outputs": ["{projectRoot}/release"],
      "options": {
        "command": "bun run scripts/package-windows.ts",
        "cwd": "apps/application-registry-desktop"
      }
    },
    "start:windows:wsl": {
      "executor": "nx:run-commands",
      "cache": false,
      "dependsOn": ["package:windows"],
      "options": {
        "command": "bun run scripts/start-windows.ts",
        "cwd": "apps/application-registry-desktop"
      }
    },
    "format": {},
    "format:check": {},
    "lint": {},
    "lint:fix": {},
    "test:unit": {
      "dependsOn": [
        {
          "projects": ["application-registry-desktop-contract"],
          "target": "build"
        }
      ]
    },
    "typecheck": {
      "dependsOn": [
        {
          "projects": ["application-registry-desktop-contract"],
          "target": "build"
        }
      ]
    }
  }
}
