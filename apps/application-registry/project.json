{
  "name": "application-registry-management",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/application-registry/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "vite build --config apps/application-registry/vite.config.ts"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "vite --config apps/application-registry/vite.config.ts"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "vite preview --config apps/application-registry/vite.config.ts"
      }
    },
    "format": {},
    "format:check": {},
    "lint": {},
    "lint:fix": {},
    "compiler:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx react-compiler-healthcheck --src 'apps/application-registry/src/**/*.{ts,tsx}'"
      }
    },
    "test:unit": {
      "options": {
        "command": "bun test --preload apps/application-registry/test/setup.ts apps/application-registry/src"
      }
    },
    "typecheck": {},
    "storybook:dev": {
      "executor": "nx:run-commands",
      "cache": false,
      "options": {
        "command": "storybook dev --config-dir apps/application-registry/.storybook --port 4403"
      }
    },
    "storybook:build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/storybook-static"],
      "options": {
        "command": "storybook build --config-dir apps/application-registry/.storybook --output-dir apps/application-registry/storybook-static"
      }
    },
    "storybook:static": {
      "executor": "@nx/web:file-server",
      "dependsOn": ["storybook:build"],
      "options": {
        "buildTarget": "application-registry-management:storybook:build",
        "staticFilePath": "apps/application-registry/storybook-static",
        "spa": true
      }
    }
  }
}
