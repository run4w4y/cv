@media print {
  @page {
    size: A4;
    margin: 8mm 9mm 12.75mm;

    @bottom-left {
      border-top: 0.25mm solid rgb(226 232 240);
      padding-top: 2mm;
      color: rgb(100 116 139);
      content: {{cssString sourceCode}};
      font-family: 'Geist Mono Variable', 'SFMono-Regular', 'Roboto Mono', 'Cascadia Code', 'Liberation Mono', monospace;
      font-size: 6.5pt;
      font-weight: 400;
      line-height: 1.2;
      text-align: left;
      vertical-align: top;
      white-space: nowrap;
    }

    @bottom-center {
      border-top: 0.25mm solid rgb(226 232 240);
      content: "";
      vertical-align: top;
    }

    @bottom-right {
      border-top: 0.25mm solid rgb(226 232 240);
      padding-top: 2mm;
      color: rgb(100 116 139);
      content: {{cssString pageLabel}} " " counter(page) " / " counter(pages);
      font-family: 'Geist Mono Variable', 'SFMono-Regular', 'Roboto Mono', 'Cascadia Code', 'Liberation Mono', monospace;
      font-size: 6.5pt;
      font-weight: 400;
      line-height: 1.2;
      text-align: right;
      vertical-align: top;
      white-space: nowrap;
    }
  }

  @page :first {
    @bottom-left {
      content: {{cssString firstPageName}};
    }
  }
}
