---
import { getPrivateRoutes } from 'virtual:content/generated'
import type { ProfileSlug } from '@cv/content-core'
import { CvPrivateRoot } from '@/components/cv/cv-private-root'
import { CvStaticRoot } from '@/components/cv/cv-static-root'
import SocialMeta from '@/components/social-meta.astro'
import { loadCv } from '@/lib/cv-content'
import type { Locale } from '@/lib/i18n'
import { localePath, locales, privateAudiencePath } from '@/lib/i18n'
import type { CvPageContextValue } from '@/lib/private-content-session/page-context'
import { faviconPath } from '@/lib/site-assets'
import { getPrivateAudienceCvUrl, getWebCvUrl } from '@/lib/web-cv'
import colorSchemeBootScriptSource from '../../../../libs/color-scheme/dist/browser/boot.js?raw'
import colorSchemeRuntimeScriptSource from '../../../../libs/color-scheme/dist/browser/runtime.js?raw'
import '@/styles/global.css'

type Props = {
  audience?: string
  contentProfile?: ProfileSlug
  lang: Locale
  privateAccess?: boolean
  profile?: ProfileSlug
  profileId?: string
}

const {
  audience,
  contentProfile = Astro.props.privateAccess ? 'default' : Astro.props.profile,
  lang,
  privateAccess = false,
  profile = 'default',
  profileId,
} = Astro.props
const publicProfile = contentProfile ?? profile
const resolvedProfileId =
  profileId ??
  getPrivateRoutes().find(
    (route) => route.lang === lang && route.profile === publicProfile
  )?.profileId
const { alternates, content } = await loadCv(lang, {
  profile: publicProfile,
})
const localeHrefs = Object.fromEntries(
  locales.map((locale) => [
    locale,
    audience ? privateAudiencePath(locale, audience) : localePath(locale),
  ])
) as Partial<Record<Locale, string>>
const webUrl = audience
  ? getPrivateAudienceCvUrl(lang, audience)
  : getWebCvUrl(lang)
const page = {
  audience,
  contentProfile: publicProfile,
  locale: lang,
  localeHrefs,
  profile,
  profileId: resolvedProfileId,
  webUrl,
} satisfies CvPageContextValue
const colorSchemeRuntimeScript = privateAccess
  ? ''
  : colorSchemeRuntimeScriptSource.trim()
---

<!doctype html>
<html
  data-cv-audience={audience}
  data-cv-content-profile={publicProfile}
  data-cv-locale={lang}
  data-cv-profile={profile}
  data-cv-profile-id={resolvedProfileId}
  data-cv-web-url={webUrl}
  dir={content.document.dir}
  lang={lang}
>
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <meta content={content.document.meta.description} name="description" />
    <link href={faviconPath} rel="icon" type="image/svg+xml" />
    <link href={webUrl} rel="canonical" />
    <SocialMeta
      description={content.document.meta.description}
      title={content.document.meta.title}
      url={webUrl}
    />
    <script is:inline set:html={colorSchemeBootScriptSource.trim()} />
    {
      alternates.map((alternate) => (
        <link
          href={localeHrefs[alternate]}
          hreflang={alternate}
          rel="alternate"
        />
      ))
    }
    <title>{content.document.meta.title}</title>
  </head>
  <body>
    {
      privateAccess ? (
        <CvPrivateRoot client:load page={page} />
      ) : (
        <CvStaticRoot content={content} page={page} />
      )
    }
    {
      colorSchemeRuntimeScript ? (
        <script is:inline set:html={colorSchemeRuntimeScript} />
      ) : null
    }
    <script>
      import { bindPrintControls } from '@/browser/print-runtime'

      bindPrintControls()
    </script>
  </body>
</html>
