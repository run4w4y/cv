---
import CvLayout from '@/layouts/cv-layout.astro'
import { isLocale, locales } from '@/lib/i18n'

export const getStaticPaths = () =>
  locales.map((lang) => ({ params: { lang } }))

const lang = Astro.params.lang

if (!isLocale(lang)) {
  return Astro.redirect('/en/')
}
---

<CvLayout lang={lang} />
