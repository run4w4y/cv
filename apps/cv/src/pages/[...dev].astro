---
import { getLocales, getPrivateRoutes } from 'virtual:content/generated'
import {
  type MintedPrivateAudienceLink,
  mintPrivateAudienceLinkFromSecrets,
  type PrivateContentProfileRoute,
} from '@cv/content-build'
import {
  decodeWebBaseUrl,
  type Locale,
  type ProfileSlug,
} from '@cv/content-core'
import {
  missingPrivateContentAccessEnv,
  type PrivateContentBuildSecrets,
  readPrivateAudienceKeyFromEnv,
  readPrivateContentIdSaltFromEnv,
  readRequiredPrivateContentBuildSecretsFromEnv,
} from '@cv/private-content-config'
import { runPrivateCryptoPromise } from '@cv/private-content-crypto'
import { buttonVariants } from '@cv/ui/button'
import { cn } from '@cv/ui/utils'
import type * as Redacted from 'effect/Redacted'
import { defaultLocale, localeNames, privateAudiencePath } from '@/lib/i18n'
import '@/styles/global.css'

const devProfilesPath = '__dev/profiles'

type DevProfileLink = {
  audience: string
  audienceId?: string
  command: string
  error?: string
  lang: Locale
  minted?: MintedPrivateAudienceLink
  profile: ProfileSlug
  profileId: string
  routePath?: string
}

type DevPrivateLinkConfig = {
  audienceKey: Redacted.Redacted<string>
  contentIdSalt: string
  privateSecrets: PrivateContentBuildSecrets
}

export const getStaticPaths = () =>
  import.meta.env.DEV ? [{ params: { dev: '__dev/profiles' } }] : []

const route = Astro.params.dev

if (!import.meta.env.DEV || route !== devProfilesPath) {
  return Astro.redirect('/en/')
}

const missingPrivateEnv = missingPrivateContentAccessEnv(process.env)
const hasPrivateSecrets = missingPrivateEnv.length === 0
const loadDevPrivateLinkConfig = (): DevPrivateLinkConfig => ({
  audienceKey: readPrivateAudienceKeyFromEnv(),
  contentIdSalt: readPrivateContentIdSaltFromEnv(),
  privateSecrets: readRequiredPrivateContentBuildSecretsFromEnv(),
})

const locales = getLocales()
const generatedPrivateRoutes = getPrivateRoutes()
const origin = Astro.url.origin
const webBaseUrl = decodeWebBaseUrl(origin)

const messageFromError = (error: unknown) =>
  error instanceof Error ? error.message : String(error)

const devAudienceForProfile = (profileId: string) => {
  const slug = profileId
    .replace(/[^a-zA-Z0-9]+/gu, '-')
    .replace(/^-+|-+$/gu, '')
    .toLowerCase()

  return `dev-${slug || 'profile'}`
}

const privateLinkCommand = ({
  audience,
  lang,
  profile,
}: {
  audience: string
  lang: Locale
  profile: string
}) =>
  `nx run private-content-link:link -- --profile ${profile} --audience ${audience} --locale ${lang} --base-url ${origin}`

const linkForRoute = async (
  route: PrivateContentProfileRoute,
  config: DevPrivateLinkConfig
): Promise<DevProfileLink> => {
  const audience = devAudienceForProfile(route.profileId)

  try {
    const minted = await runPrivateCryptoPromise(
      mintPrivateAudienceLinkFromSecrets({
        audience,
        audienceKey: config.audienceKey,
        baseUrl: webBaseUrl,
        contentIdSalt: config.contentIdSalt,
        locale: route.lang,
        profile: route.profile,
        secrets: config.privateSecrets,
      })
    )

    return {
      audience,
      audienceId: minted.audienceId,
      command: privateLinkCommand({
        audience,
        lang: route.lang,
        profile: route.profile,
      }),
      lang: route.lang,
      minted,
      profile: minted.profile,
      profileId: route.profileId,
      routePath: privateAudiencePath(route.lang, minted.audienceId),
    }
  } catch (error) {
    return {
      audience,
      command: privateLinkCommand({
        audience,
        lang: route.lang,
        profile: route.profile,
      }),
      error: messageFromError(error),
      lang: route.lang,
      profile: route.profile,
      profileId: route.profileId,
      routePath: undefined,
    }
  }
}

let privateLinkError: string | null = null
let profileLinks: DevProfileLink[] = []

if (hasPrivateSecrets) {
  try {
    const privateConfig = loadDevPrivateLinkConfig()

    profileLinks = await Promise.all(
      generatedPrivateRoutes.map((privateRoute) =>
        linkForRoute(privateRoute, privateConfig)
      )
    )
  } catch (error) {
    privateLinkError = messageFromError(error)
  }
} else {
  privateLinkError = `Missing ${missingPrivateEnv.join(', ')}.`
}

if (profileLinks.length === 0) {
  profileLinks =
    generatedPrivateRoutes.length > 0
      ? generatedPrivateRoutes.map((privateRoute) => {
          const audience = devAudienceForProfile(privateRoute.profileId)

          return {
            audience,
            command: privateLinkCommand({
              audience,
              lang: privateRoute.lang,
              profile: privateRoute.profile,
            }),
            error: privateLinkError ?? 'Private access link was not minted.',
            lang: privateRoute.lang,
            profile: privateRoute.profile,
            profileId: privateRoute.profileId,
            routePath: undefined,
          }
        })
      : []
}

const profileSort = (left: string, right: string) =>
  left === 'default' ? -1 : right === 'default' ? 1 : left.localeCompare(right)
const profiles = [...new Set(profileLinks.map((link) => link.profile))].sort(
  profileSort
)
const linksByProfile = new Map(
  profiles.map((profile) => [
    profile,
    profileLinks
      .filter((link) => link.profile === profile)
      .sort((left, right) => left.lang.localeCompare(right.lang)),
  ])
)
---

<!doctype html>
<html lang={defaultLocale}>
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <meta content="noindex, nofollow, noarchive" name="robots" />
    <title>CV Dev Profiles</title>
  </head>
  <body>
    <main
      class="mx-auto min-h-dvh max-w-7xl border-x border-border bg-background/80"
    >
      <header class="border-b border-border px-5 py-6 sm:px-8">
        <p class="font-mono text-xs/5 uppercase text-primary">CV Dev</p>
        <h1 class="mt-3 font-mono text-3xl/9 text-foreground">
          Private Profile Index
        </h1>
        <div
          class="mt-4 grid gap-3 font-mono text-xs/5 text-muted-foreground sm:grid-cols-3"
        >
          <p>{profiles.length} private profiles</p>
          <p>{locales.length} locales</p>
          <p>{profileLinks.length} encrypted routes</p>
        </div>
      </header>

      <section class="border-b border-border px-5 py-5 sm:px-8">
        <div class="border border-border bg-card/45 p-4">
          <p class="font-mono text-xs/5 uppercase text-primary">
            Encrypted Dev Access
          </p>
          <p class="mt-2 max-w-3xl text-sm/6 text-muted-foreground">
            {
              hasPrivateSecrets
                ? 'Private runtime secrets are present. The links below use the same encrypted profile routes and token unlock flow as the real CV.'
                : 'Private runtime secrets are not fully present in this shell, so unlocked profile links cannot be minted.'
            }
          </p>
          {
            privateLinkError ? (
              <p class="mt-2 max-w-3xl font-mono text-xs/5 text-destructive">
                {privateLinkError}
              </p>
            ) : null
          }
        </div>
      </section>

      <section>
        {
          profiles.map((profile) => (
            <article class="border-b border-border" data-dev-profile={profile}>
              <div class="grid gap-4 px-5 py-5 sm:px-8 lg:grid-cols-[12rem_1fr]">
                <div>
                  <p class="font-mono text-xs/5 uppercase text-muted-foreground">
                    Content Profile
                  </p>
                  <h2 class="mt-2 font-mono text-lg/7 text-foreground">
                    {profile}
                  </h2>
                </div>
                <div class="grid gap-3">
                  {linksByProfile.get(profile)?.map((link) => (
                    <div class="grid gap-3 border border-border bg-card/35 p-3 md:grid-cols-[8rem_minmax(0,1fr)]">
                      <div class="flex flex-wrap items-center gap-2">
                        {link.minted ? (
                          <a
                            class={cn(
                              buttonVariants({
                                size: 'toolbar-tab',
                                variant:
                                  link.lang === defaultLocale
                                    ? 'toolbar-active'
                                    : 'toolbar',
                              }),
                              'font-mono uppercase'
                            )}
                            href={link.minted.url}
                          >
                            {localeNames[link.lang] ?? link.lang.toUpperCase()}
                          </a>
                        ) : (
                          <span
                            class={cn(
                              buttonVariants({
                                size: 'toolbar-tab',
                                variant: 'toolbar',
                              }),
                              'pointer-events-none font-mono uppercase opacity-45'
                            )}
                          >
                            {localeNames[link.lang] ?? link.lang.toUpperCase()}
                          </span>
                        )}
                      </div>
                      <div class="grid min-w-0 gap-2">
                        <div class="grid gap-2">
                          <code class="min-w-0 overflow-x-auto border border-border bg-background px-3 py-2 font-mono text-xs/5 text-muted-foreground">
                            {link.routePath ??
                              'Encrypted route not generated in this shell'}
                          </code>
                        </div>
                        <code class="min-w-0 overflow-x-auto border border-border bg-background px-3 py-2 font-mono text-xs/5 text-muted-foreground">
                          {link.command}
                        </code>
                        <code class="min-w-0 overflow-x-auto border border-border bg-background px-3 py-2 font-mono text-xs/5 text-muted-foreground">
                          audience {link.audience}
                          {link.audienceId ? ` / id ${link.audienceId}` : ''}
                          {' / '}
                          profile {link.profileId}
                        </code>
                        {link.error ? (
                          <p class="font-mono text-xs/5 text-destructive">
                            {link.error}
                          </p>
                        ) : null}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </section>
    </main>
  </body>
</html>
