{
  "name": "cv",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/cv/src",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../node_modules/.bin/astro dev --host 0.0.0.0",
        "cwd": "apps/cv",
        "color": true
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "cd apps/cv && ../../node_modules/.bin/tsc --pretty --noEmit --project tsconfig.config.json && ../../node_modules/.bin/astro check && ../../node_modules/.bin/astro build",
        "cwd": ".",
        "color": true
      }
    },
    "i18n:compile": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "command": "../../node_modules/.bin/lingui compile --strict --namespace es --config lingui.config.ts",
        "cwd": "apps/cv",
        "color": true
      }
    },
    "i18n:extract": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "command": "../../node_modules/.bin/lingui extract --config lingui.config.ts",
        "cwd": "apps/cv",
        "color": true
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../node_modules/.bin/astro preview",
        "cwd": "apps/cv",
        "color": true
      }
    },
    "preview:pdf": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../node_modules/.bin/astro preview --host 127.0.0.1 --port 4322",
        "cwd": "apps/cv",
        "color": true
      }
    },
    "lint": {},
    "lint:fix": {},
    "typecheck": {
      "options": {
        "command": "cd apps/cv && ../../node_modules/.bin/tsc --pretty --noEmit --project tsconfig.config.json && ../../node_modules/.bin/astro check"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "command": "playwright test -c apps/cv/playwright.config.ts",
        "cwd": ".",
        "color": true
      }
    },
    "test:unit": {},
    "format": {},
    "format:check": {}
  }
}
