{
  "name": "cv",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/cv/src",
  "tags": ["scope:cv", "type:worker", "visibility:public"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun run dev",
        "cwd": "apps/cv",
        "color": true
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/.next", "{projectRoot}/.open-next"],
      "options": {
        "command": "./node_modules/.bin/opennextjs-cloudflare build",
        "cwd": "apps/cv",
        "color": true
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "outputs": [],
      "options": {
        "commands": [
          "bun apps/cv/scripts/write-wrangler-config.ts apps/cv/wrangler.deploy.jsonc",
          "bun apps/cv/scripts/deploy.ts apps/cv/wrangler.deploy.jsonc"
        ],
        "parallel": false,
        "cwd": ".",
        "color": true
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "./node_modules/.bin/opennextjs-cloudflare preview",
        "cwd": "apps/cv",
        "color": true
      }
    },
    "test:worker": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "outputs": [],
      "options": {
        "commands": [
          "node node_modules/wrangler/bin/wrangler.js deploy --dry-run --config apps/cv/wrangler.jsonc --outfile apps/cv/.open-next/deploy-check/worker.js",
          "node --import tsx --test apps/cv/test/public-worker.integration.test.ts"
        ],
        "parallel": false,
        "cwd": ".",
        "color": true
      }
    },
    "lint": {},
    "lint:fix": {},
    "typecheck": {},
    "test:unit": {},
    "format": {},
    "format:check": {}
  }
}
