{
  "name": "cv",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/cv/src",
  "tags": ["scope:cv", "type:worker", "visibility:public"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "../../node_modules/.bin/astro dev --host 0.0.0.0",
        "cwd": "apps/cv",
        "color": true
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "../../node_modules/.bin/tsc --pretty --noEmit --project tsconfig.config.json && ../../node_modules/.bin/astro check && ../../node_modules/.bin/astro build",
        "cwd": "apps/cv",
        "color": true
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "outputs": [],
      "options": {
        "commands": [
          "bun apps/cv/scripts/write-wrangler-config.ts apps/cv/dist/server/wrangler.deploy.json",
          "bunx wrangler deploy --config apps/cv/dist/server/wrangler.deploy.json"
        ],
        "parallel": false,
        "cwd": ".",
        "color": true
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "../../node_modules/.bin/astro preview",
        "cwd": "apps/cv",
        "color": true
      }
    },
    "test:worker": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "outputs": [],
      "options": {
        "command": "node --import tsx --test apps/cv/test/public-worker.integration.test.ts",
        "cwd": ".",
        "color": true
      }
    },
    "lint": {},
    "lint:fix": {},
    "typecheck": {},
    "test:unit": {},
    "format": {},
    "format:check": {}
  }
}
