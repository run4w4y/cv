{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "cv-public",
  "main": "worker.ts",
  "compatibility_date": "2026-07-19",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "cache": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "vars": {
    "CV_PUBLIC_RESOLVER_URL": "http://127.0.0.1:3000"
  }
}
