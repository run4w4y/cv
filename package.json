{
  "name": "@cv/source",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "libs/*",
    "libs/application-registry/*",
    "tools/*"
  ],
  "scripts": {
    "content:types": "bun run tools/content-types/src/generate.ts --source apps/cv/src/cv-content/schema/registry.ts --authoring apps/cv/src/cv-content/authoring/components.tsx --out ${CONTENT_ROOT:-../cv-content}/types/content-authoring.d.ts",
    "format": "biome format --write .github apps fixtures libs tools biome.json nx.json package.json tsconfig.base.json tsconfig.json",
    "format:check": "biome format --error-on-warnings .github apps fixtures libs tools biome.json nx.json package.json tsconfig.base.json tsconfig.json",
    "lint": "biome lint --error-on-warnings .github apps fixtures libs tools biome.json nx.json package.json tsconfig.base.json tsconfig.json",
    "lint:fix": "biome lint --write .github apps fixtures libs tools biome.json nx.json package.json tsconfig.base.json tsconfig.json",
    "quality:biome": "biome ci --error-on-warnings .github apps fixtures libs tools biome.json nx.json package.json tsconfig.base.json tsconfig.json",
    "quality": "bun run quality:biome && nx run-many -t typecheck test:unit --parallel=6"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@base-ui/react": "^1.4.1",
    "@effect/atom-react": "4.0.0-beta.91",
    "@effect/platform-bun": "4.0.0-beta.91",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@lingui/core": "^6.4.0",
    "@lingui/react": "^6.4.0",
    "@tailwindcss/vite": "^4.1.17",
    "astro": "^7.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cssesc": "^3.0.0",
    "devicon": "^2.17.0",
    "effect": "4.0.0-beta.91",
    "handlebars": "^4.7.9",
    "lucide-react": "^1.14.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.17",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@biomejs/biome": "^2.5.2",
    "@cloudflare/workers-types": "4.20260511.1",
    "@effect/platform-node": "4.0.0-beta.91",
    "@lingui/babel-plugin-lingui-macro": "^6.4.0",
    "@lingui/cli": "^6.4.0",
    "@lingui/vite-plugin": "^6.4.0",
    "@nx/js": "21.2.1",
    "@nx/web": "21.0.3",
    "@nx/workspace": "21.0.3",
    "@playwright/test": "1.61.1",
    "@storybook/addon-docs": "^9.0.13",
    "@storybook/react-vite": "^9.0.13",
    "@types/bun": "^1.1.14",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "bun-types": "^1.3.14",
    "nx": "21.0.3",
    "playwright": "1.61.1",
    "shadcn": "^4.7.0",
    "storybook": "^9.0.13",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2",
    "vite": "^8.1.3",
    "wrangler": "^4.110.0"
  }
}
