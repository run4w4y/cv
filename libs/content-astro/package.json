    }
  },
  "dependencies": {
    "@cv/content-build": "workspace:*",
    "@cv/content-composer": "workspace:*",
    "@cv/content-core": "workspace:*",
    "@cv/private-content-crypto": "workspace:*",
    "@cv/private-content-protocol": "workspace:*",
    "@effect/platform-node": "4.0.0-beta.91",
    "astro": "^7.0.6",
    "effect": "4.0.0-beta.91",
    "handlebars": "^4.7.9",
    "react": "^19.0.0",
    "satteri": "^0.9.2",
    "tslib": "^2.8.1",
    "vite": "^8.1.3"
  }
