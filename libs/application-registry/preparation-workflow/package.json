      "types": "./dist/public/cover-letter.d.ts",
      "default": "./dist/public/cover-letter.js"
    },
    "./cv": {
      "types": "./dist/public/cv.d.ts",
      "default": "./dist/public/cv.js"
    },
    "./domain": {
      "types": "./dist/public/domain.d.ts",
      "default": "./dist/public/domain.js"
    },
    "./test-support": {
      "types": "./dist/test-support/index.d.ts",
      "default": "./dist/test-support/index.js"
    }
  },
  "dependencies": {
    "@cv/ai-provider": "workspace:*",
    "@cv/application-registry-entity": "workspace:*",
    "@cv/contracts": "workspace:*",
    "effect": "4.0.0-beta.99"
  }
