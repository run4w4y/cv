{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "content-build",
  "projectType": "library",
  "sourceRoot": "libs/content-build/src",
  "tags": ["scope:cv", "type:build"],
  "targets": {
    "build": {
      "executor": "nx:noop",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": [
        {
          "projects": "self",
          "target": "build:js"
        }
      ]
    },
    "lint": {},
    "lint:fix": {},
    "test:unit": {},
    "typecheck": {},
    "build:tsc": {
      "executor": "@nx/js:tsc",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "main": "libs/content-build/src/index.ts",
        "outputPath": "libs/content-build/dist",
        "rootDir": "libs/content-build/src",
        "tsConfig": "libs/content-build/tsconfig.build.json",
        "generatePackageJson": false
      }
    },
    "build:js": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": "self",
          "target": "build:tsc"
        }
      ],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "color": true,
        "command": "vite build --config libs/content-build/vite.lib.config.ts"
      }
    },
    "format": {},
    "format:check": {}
  }
}
