{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "private-content-session",
  "projectType": "library",
  "sourceRoot": "libs/private-content-session/src",
  "tags": ["scope:cv", "type:runtime"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "main": "libs/private-content-session/src/index.ts",
        "outputPath": "libs/private-content-session/dist",
        "rootDir": "libs/private-content-session/src",
        "tsConfig": "libs/private-content-session/tsconfig.build.json",
        "generatePackageJson": false
      }
    },
    "test": {
      "executor": "nx:noop",
      "dependsOn": [
        {
          "projects": "self",
          "target": "test:unit"
        }
      ],
      "outputs": []
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "cd libs/private-content-session && bun test src"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome check libs/private-content-session"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome check --write libs/private-content-session"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "command": "tsc --pretty --noEmit --project libs/private-content-session/tsconfig.json"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome format --write libs/private-content-session"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome format libs/private-content-session"
      }
    }
  }
}
