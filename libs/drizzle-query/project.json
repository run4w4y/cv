{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "drizzle-query",
  "projectType": "library",
  "sourceRoot": "libs/drizzle-query/src",
  "tags": ["scope:shared", "type:core", "visibility:private"],
  "targets": {
    "build": {
      "executor": "nx:noop",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": [
        {
          "projects": "self",
          "target": "build:js"
        }
      ]
    },
    "build:tsc": {
      "executor": "@nx/js:tsc",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "main": "libs/drizzle-query/src/index.ts",
        "outputPath": "libs/drizzle-query/dist",
        "rootDir": "libs/drizzle-query/src",
        "tsConfig": "libs/drizzle-query/tsconfig.build.json",
        "generatePackageJson": false
      }
    },
    "build:js": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": "self",
          "target": "build:tsc"
        }
      ],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "color": true,
        "command": "vite build --config libs/drizzle-query/vite.lib.config.ts"
      }
    },
    "lint": {},
    "lint:fix": {},
    "test:unit": {
      "dependsOn": ["build"]
    },
    "typecheck": {},
    "format": {},
    "format:check": {}
  }
}
