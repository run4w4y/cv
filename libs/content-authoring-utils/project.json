{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "content-authoring-utils",
  "projectType": "library",
  "sourceRoot": "libs/content-authoring-utils/src",
  "tags": ["scope:cv", "type:build"],
  "targets": {
    "build": {
      "executor": "nx:noop",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": [
        {
          "projects": "self",
          "target": "build:js"
        }
      ]
    },
    "lint": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome check libs/content-authoring-utils"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome check --write libs/content-authoring-utils"
      }
    },
    "test": {
      "executor": "nx:noop",
      "dependsOn": [
        {
          "projects": "self",
          "target": "test:unit"
        }
      ],
      "outputs": []
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "bun test libs/content-authoring-utils/src"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "command": "tsc --pretty --noEmit --project libs/content-authoring-utils/tsconfig.json"
      }
    },
    "build:tsc": {
      "executor": "@nx/js:tsc",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "main": "libs/content-authoring-utils/src/index.ts",
        "outputPath": "libs/content-authoring-utils/dist",
        "rootDir": "libs/content-authoring-utils/src",
        "tsConfig": "libs/content-authoring-utils/tsconfig.build.json",
        "generatePackageJson": false
      }
    },
    "build:js": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": "self",
          "target": "build:tsc"
        }
      ],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "color": true,
        "command": "vite build --config libs/content-authoring-utils/vite.lib.config.ts"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome format --write libs/content-authoring-utils"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome format libs/content-authoring-utils"
      }
    }
  }
}
