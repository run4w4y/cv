{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "handlebars-css-template",
  "projectType": "library",
  "sourceRoot": "libs/handlebars-css-template/src",
  "tags": ["scope:cv", "type:tooling"],
  "targets": {
    "build": {
      "executor": "nx:noop",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": [
        {
          "projects": "self",
          "target": "build:js"
        }
      ]
    },
    "lint": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome check libs/handlebars-css-template"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome check --write libs/handlebars-css-template"
      }
    },
    "test": {
      "executor": "nx:noop",
      "dependsOn": [
        {
          "projects": "self",
          "target": "test:unit"
        }
      ],
      "outputs": []
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "bun test libs/handlebars-css-template/src"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "command": "tsc --pretty --noEmit --project libs/handlebars-css-template/tsconfig.json"
      }
    },
    "build:tsc": {
      "executor": "@nx/js:tsc",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "main": "libs/handlebars-css-template/src/index.ts",
        "outputPath": "libs/handlebars-css-template/dist",
        "rootDir": "libs/handlebars-css-template/src",
        "tsConfig": "libs/handlebars-css-template/tsconfig.build.json",
        "generatePackageJson": false,
        "assets": [
          {
            "input": "libs/handlebars-css-template/src",
            "glob": "vendor/cssesc.d.ts",
            "output": "."
          }
        ]
      }
    },
    "build:js": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": "self",
          "target": "build:tsc"
        }
      ],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "color": true,
        "command": "vite build --config libs/handlebars-css-template/vite.lib.config.ts"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome format --write libs/handlebars-css-template"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome format libs/handlebars-css-template"
      }
    }
  }
}
