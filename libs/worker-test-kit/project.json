{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "worker-test-kit",
  "projectType": "library",
  "sourceRoot": "libs/worker-test-kit/src",
  "tags": ["scope:test", "type:test-support", "visibility:private"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "main": "libs/worker-test-kit/src/index.ts",
        "outputPath": "libs/worker-test-kit/dist",
        "rootDir": "libs/worker-test-kit/src",
        "tsConfig": "libs/worker-test-kit/tsconfig.build.json",
        "generatePackageJson": false
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "outputs": [],
      "options": {
        "color": true,
        "command": "node --import tsx --test libs/worker-test-kit/test/*.integration.test.ts"
      }
    },
    "lint": {},
    "lint:fix": {},
    "test:unit": {},
    "typecheck": {},
    "format": {},
    "format:check": {}
  }
}
