{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "cloudflare-analytics-client",
  "projectType": "library",
  "sourceRoot": "libs/cloudflare-analytics-client/src",
  "tags": ["scope:analytics", "type:client", "visibility:private"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "main": "libs/cloudflare-analytics-client/src/index.ts",
        "outputPath": "libs/cloudflare-analytics-client/dist",
        "rootDir": "libs/cloudflare-analytics-client/src",
        "tsConfig": "libs/cloudflare-analytics-client/tsconfig.build.json",
        "generatePackageJson": false
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome check libs/cloudflare-analytics-client"
      }
    },
    "lint:fix": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome check --write libs/cloudflare-analytics-client"
      }
    },
    "test": {
      "executor": "nx:noop",
      "dependsOn": [
        {
          "projects": "self",
          "target": "test:all"
        }
      ],
      "outputs": []
    },
    "test:all": {
      "executor": "nx:noop",
      "dependsOn": [
        {
          "projects": "self",
          "target": "test:unit"
        },
        {
          "projects": "self",
          "target": "typecheck"
        }
      ],
      "outputs": []
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/coverage"],
      "options": {
        "color": true,
        "command": "bun test --coverage",
        "cwd": "libs/cloudflare-analytics-client"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "tsc --pretty --noEmit --project libs/cloudflare-analytics-client/tsconfig.json",
        "cwd": "."
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "cache": false,
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome format --write libs/cloudflare-analytics-client"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "outputs": [],
      "options": {
        "color": true,
        "command": "biome format libs/cloudflare-analytics-client"
      }
    }
  }
}
