{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "strict": true
  },
  "files": [],
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    ".storybook/**/*",
    "node_modules",
    "dist",
    "storybook-static",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test-utils.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
