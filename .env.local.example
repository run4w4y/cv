# Copy this file to .env.local only when a task needs Infisical-backed values.
# No remote secrets are loaded during ordinary direnv activation.
INFISICAL_ENV=replace-with-environment-slug
INFISICAL_PROJECT_ID=replace-with-project-id

# Comma-separated, least-privilege paths required for the current task.
# Example: /cv/application-registry,/cv/analytics
CV_INFISICAL_PATHS=
