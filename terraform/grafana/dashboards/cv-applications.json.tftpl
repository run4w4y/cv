        },
        {
          "id": "filterByValue",
          "options": {
            "filters": [
              {
                "config": {
                  "id": "regex",
                  "options": {
                    "value": "^($${company:regex})$"
                  }
                },
                "fieldName": "company"
              },
              {
                "config": {
                  "id": "regex",
                  "options": {
                    "value": "^($${applicationStatus:regex})$"
                  }
                },
                "fieldName": "applicationStatus"
