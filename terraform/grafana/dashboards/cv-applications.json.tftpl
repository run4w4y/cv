          "filters": [],
          "format": "table",
          "global_query_id": "",
          "pagination_max_pages": 5,
          "pagination_mode": "cursor",
          "pagination_param_cursor_extraction_path": "pageInfo.nextCursor",
          "pagination_param_cursor_field_name": "after",
          "pagination_param_cursor_field_type": "query",
          "pagination_param_size_field_name": "size",
          "pagination_param_size_field_type": "query",
          "pagination_param_size_value": 100,
          "parser": "backend",
          "refId": "A",
          "root_selector": "($reference := $${__to}; $minimum := \"$${fitScoreMin}\"; $maximum := \"$${fitScoreMax}\"; $minimumValue := $minimum = \"\" ? null : $number($minimum); $maximumValue := $maximum = \"\" ? null : $number($maximum); $rows := items[($minimumValue = null ? true : (fitScore != null ? fitScore >= $minimumValue : false)) and ($maximumValue = null ? true : (fitScore != null ? fitScore <= $maximumValue : false))]; $count($rows) > 0 ? $map($rows, function($item) { $merge([$item, {\"followUpTiming\": $item.followUpAt = null or $not($exists($item.followUpAt)) ? \"none\" : $toMillis($item.followUpAt) <= $reference ? \"overdue\" : \"upcoming\"}]) }) : [{\"id\":\"__grafana_empty__\"}])",
          "source": "url",
          "type": "json",
          "url": "${registry_api_url}/v1/applications",
          "url_options": {
            "data": "",
            "method": "GET",
            "params": [
              {
                "key": "size",
                "value": "100"
              },
              {
                "key": "currency",
                "value": "$${compensationCurrency}"
              },
              {
                "key": "filters",
                "value": "$${view.filters}"
              },
              {
                "key": "orderBy",
                "value": "$${view.orderBy}"
              }
            ]
          }
        }
