              {
                "id": "actions",
                "value": [
                  {
                    "title": "Change status",
                    "type": "fetch",
                    "confirmation": "Record $eventKind and move $${__data.fields[\"company\"]} — $${__data.fields[\"role\"]} to $nextStatus?",
                    "oneClick": false,
                    "style": {
                      "backgroundColor": "#1f60c4"
                    },
                    "variables": [
                      {
                        "key": "eventKind",
                        "name": "Event kind",
                        "type": "string"
                      },
                      {
                        "key": "nextStatus",
                        "name": "Next lifecycle status",
                        "type": "string"
                      }
                    ],
                    "fetch": {
                      "method": "POST",
                      "url": "/api/datasources/proxy/uid/${application_registry_datasource_uid}/v1/applications/$${__data.fields[\"id\"]}/events",
                      "headers": [
                        [
                          "Content-Type",
                          "application/json"
                        ]
                      ],
                      "queryParams": [],
                      "body": "{\n  \"deviceId\": null,\n  \"expectedVersion\": $${__data.fields[\"version\"]},\n  \"kind\": \"$eventKind\",\n  \"nextApplicationStatus\": \"$nextStatus\",\n  \"occurredAt\": \"$${__to:date:iso}\",\n  \"operationId\": \"grafana-status-$${__data.fields[\"id\"]}-$${__data.fields[\"version\"]}-$eventKind-$nextStatus\",\n  \"payload\": {}\n}"
                    }
                  },
                  {
                    "title": "Add note",
                    "type": "fetch",
                    "confirmation": "Add a $noteKind note to $${__data.fields[\"company\"]} — $${__data.fields[\"role\"]}?",
                    "oneClick": false,
                    "style": {
                      "backgroundColor": "#7c3aed"
                    },
                    "variables": [
                      {
                        "key": "noteKind",
                        "name": "Note kind",
                        "type": "string"
                      },
                      {
                        "key": "noteBodyJson",
                        "name": "Body as a JSON string (include quotes)",
                        "type": "string"
                      },
                      {
                        "key": "noteSourceJson",
                        "name": "Source as a JSON string or null",
                        "type": "string"
                      }
                    ],
                    "fetch": {
                      "method": "POST",
                      "url": "/api/datasources/proxy/uid/${application_registry_datasource_uid}/v1/applications/$${__data.fields[\"id\"]}/notes",
                      "headers": [
                        [
                          "Content-Type",
                          "application/json"
                        ]
                      ],
                      "queryParams": [],
                      "body": "{\n  \"body\": $noteBodyJson,\n  \"kind\": \"$noteKind\",\n  \"operationId\": \"grafana-note-$${__data.fields[\"id\"]}-$${__data.fields[\"version\"]}-$noteKind\",\n  \"source\": $noteSourceJson\n}"
                    }
                  },
                  {
                    "title": "Replace labels",
                    "type": "fetch",
                    "confirmation": "Replace every label on $${__data.fields[\"company\"]} — $${__data.fields[\"role\"]}?",
                    "oneClick": false,
                    "style": {
                      "backgroundColor": "#c2410c"
                    },
                    "variables": [
                      {
                        "key": "labelsJson",
                        "name": "Labels as JSON, for example [\"remote\",\"priority\"]",
                        "type": "string"
                      }
                    ],
                    "fetch": {
                      "method": "PUT",
                      "url": "/api/datasources/proxy/uid/${application_registry_datasource_uid}/v1/applications/$${__data.fields[\"id\"]}/labels",
                      "headers": [
                        [
                          "Content-Type",
                          "application/json"
                        ]
                      ],
                      "queryParams": [],
                      "body": "{\n  \"labels\": $labelsJson\n}"
                    }
                  },
                  {
                    "title": "Log contact",
                    "type": "fetch",
                    "confirmation": "Record contact for $${__data.fields[\"company\"]} — $${__data.fields[\"role\"]}?",
                    "oneClick": false,
                    "style": {
                      "backgroundColor": "#2e7d32"
                    },
                    "variables": [],
                    "fetch": {
                      "method": "POST",
                      "url": "/api/datasources/proxy/uid/${application_registry_datasource_uid}/v1/applications/$${__data.fields[\"id\"]}/events",
                      "headers": [
                        [
                          "Content-Type",
                          "application/json"
                        ]
                      ],
                      "queryParams": [],
                      "body": "{\n  \"deviceId\": null,\n  \"expectedVersion\": $${__data.fields[\"version\"]},\n  \"kind\": \"contact_logged\",\n  \"occurredAt\": \"$${__to:date:iso}\",\n  \"operationId\": \"grafana-contact-$${__data.fields[\"id\"]}-$${__data.fields[\"version\"]}\",\n  \"payload\": {}\n}"
                    }
                  },
                  {
                    "title": "Research updated",
                    "type": "fetch",
                    "confirmation": "Record a research update for $${__data.fields[\"company\"]} — $${__data.fields[\"role\"]}?",
                    "oneClick": false,
                    "style": {
