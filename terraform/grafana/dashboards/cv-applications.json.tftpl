              {
                "config": {
                  "id": "regex",
                  "options": {
                    "value": "^($${personalPriority:regex})$"
                  }
                },
                "fieldName": "personalPriority"
              },
              {
                "config": {
                  "id": "regex",
                  "options": {
                    "value": "\"(?:$${label:regex})\"|^(?=$${label:regex}$)\\[\\]$"
                  }
                },
                "fieldName": "labels"
              }
            ],
            "match": "all",
            "type": "include"
          }
        },
        {
