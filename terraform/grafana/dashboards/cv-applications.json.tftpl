                      "body": "{\n  \"deviceId\": null,\n  \"expectedVersion\": $${__data.fields[\"version\"]},\n  \"kind\": \"research_updated\",\n  \"occurredAt\": \"$${__to:date:iso}\",\n  \"operationId\": \"grafana-research-$${__data.fields[\"id\"]}-$${__data.fields[\"version\"]}\",\n  \"payload\": {}\n}"
                    }
                  },
                  {
                    "title": "Set follow-up",
                    "type": "fetch",
                    "confirmation": "Set the follow-up for $${__data.fields[\"company\"]} — $${__data.fields[\"role\"]} to $followUpAt?",
                    "oneClick": false,
