{
  "name": "pdf-export",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "tools/pdf-export/src",
  "tags": ["scope:cv", "type:tool"],
  "targets": {
    "public": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{workspaceRoot}/apps/cv/dist/pdf"],
      "options": {
        "command": "bun run tools/pdf-export/src/cli/public.ts",
        "color": true
      }
    },
    "profile": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{workspaceRoot}/apps/cv/dist/private-pdf"],
      "options": {
        "command": "bun run tools/pdf-export/src/cli/profile.ts",
        "color": true
      }
    },
    "lint": {},
    "lint:fix": {},
    "test:unit": {},
    "typecheck": {},
    "format": {},
    "format:check": {}
  }
}
