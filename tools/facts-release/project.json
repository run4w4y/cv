{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "facts-toolchain",
  "projectType": "application",
  "sourceRoot": "tools/facts-release/src",
  "tags": ["scope:cv", "type:tool", "visibility:private"],
  "targets": {
    "check": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": [],
      "options": {
        "command": "bun run tools/facts-release/src/cli.ts check --content-root ${CONTENT_ROOT:-../cv-content}",
        "color": true
      }
    },
    "build:artifact": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": [],
      "options": {
        "command": "bun build --compile --target=bun-linux-x64 tools/facts-release/src/cli.ts --outfile dist/facts-toolchain/cv-facts",
        "color": true
      }
    },
    "format": {},
    "format:check": {},
    "lint": {},
    "lint:fix": {},
    "test:unit": {},
    "typecheck": {}
  }
}
