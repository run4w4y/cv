{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "facts-release-publisher",
  "projectType": "application",
  "sourceRoot": "tools/facts-release/src",
  "tags": ["scope:cv", "type:tool", "visibility:private"],
  "targets": {
    "check": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": [],
      "options": {
        "command": "bun run tools/facts-release/src/check.ts --content-root ${CONTENT_ROOT:-../cv-content}",
        "color": true
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": [],
      "options": {
        "command": "bun run tools/facts-release/src/main.ts",
        "color": true
      }
    },
    "format": {},
    "format:check": {},
    "lint": {},
    "lint:fix": {},
    "test:unit": {},
    "typecheck": {}
  }
}
