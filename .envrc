use flake

dotenv_if_exists ".env.local"

infisical_user_token() {
  local domain_arg=()
  local token

  if [[ -n "${INFISICAL_TOKEN:-}" ]]; then
    printf '%s' "$INFISICAL_TOKEN"
    return
  fi

  if [[ -n "${INFISICAL_API_URL:-}" ]]; then
    domain_arg=(--domain="$INFISICAL_API_URL")
  elif [[ -n "${INFISICAL_HOST:-}" ]]; then
    domain_arg=(--domain="${INFISICAL_HOST%/}/api")
  fi

  if ! infisical user --help 2>/dev/null | grep -Eq "^[[:space:]]+get[[:space:]]"; then
    log_status "Infisical CLI cannot read the logged-in user token; run infisical login"
    return 1
  fi

  if token="$(infisical --silent user get token --plain "${domain_arg[@]}" </dev/null 2>/dev/null)" &&
    [[ "$token" =~ ^[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+$ ]]; then
    printf '%s' "$token"
    return
  fi

  log_status "Infisical user token unavailable; run infisical login"
  return 1
}

infisical_load() {
  local env_slug="${1:?Infisical environment is required}"
  local secrets_path="${2:?Infisical path is required}"
  local secrets_file
  local domain_arg=()
  local project_id_arg=()
  local token_arg=()
  local token
  local dotenv_exports

  if [[ -n "${INFISICAL_API_URL:-}" ]]; then
    domain_arg=(--domain="$INFISICAL_API_URL")
  elif [[ -n "${INFISICAL_HOST:-}" ]]; then
    domain_arg=(--domain="${INFISICAL_HOST%/}/api")
  fi

  if [[ -n "${INFISICAL_PROJECT_ID:-}" ]]; then
    project_id_arg=(--projectId="$INFISICAL_PROJECT_ID")
  fi

  if ! token="$(infisical_user_token)"; then
    log_status "Infisical secrets unavailable for ${env_slug}:${secrets_path}"
    return 1
  fi
  token_arg=(--token="$token")

  secrets_file="$(mktemp)"

  if infisical export \
    --silent \
    --env="$env_slug" \
    --path="$secrets_path" \
    --format=dotenv \
    "${domain_arg[@]}" \
    "${project_id_arg[@]}" \
    "${token_arg[@]}" \
    </dev/null >"$secrets_file"; then
    if dotenv_exports="$("$direnv" dotenv bash "$secrets_file")"; then
      eval "$dotenv_exports"
    else
      log_status "Infisical secrets unavailable for ${env_slug}:${secrets_path}; failed to parse dotenv export"
      rm -f "$secrets_file"
      return 1
    fi
  else
    log_status "Infisical secrets unavailable for ${env_slug}:${secrets_path}"
    rm -f "$secrets_file"
    return 1
  fi

  rm -f "$secrets_file"
}

if [[ -n "${CV_INFISICAL_PATHS:-}" ]]; then
  if [[ -z "${INFISICAL_ENV:-}" || -z "${INFISICAL_PROJECT_ID:-}" ]]; then
    log_status "Set INFISICAL_ENV and INFISICAL_PROJECT_ID before requesting CV_INFISICAL_PATHS"
    return 1
  fi

  IFS=',' read -r -a cv_infisical_paths <<<"$CV_INFISICAL_PATHS"
  for cv_infisical_path in "${cv_infisical_paths[@]}"; do
    cv_infisical_path="${cv_infisical_path//[[:space:]]/}"
    if [[ -n "$cv_infisical_path" ]]; then
      infisical_load "$INFISICAL_ENV" "$cv_infisical_path" || return 1
    fi
  done

  unset cv_infisical_path cv_infisical_paths
fi
