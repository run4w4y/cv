use flake

dotenv_if_exists ".env.local"
export ASTRO_TELEMETRY_DISABLED=1

export INFISICAL_PROJECT_ID="${INFISICAL_PROJECT_ID:-891e7cae-ab27-4882-82f3-9862e574464a}"
export INFISICAL_ENV="${INFISICAL_ENV:-prod}"

infisical_login_user_token() {
  local domain_arg=()
  local token

  if [[ -n "${INFISICAL_TOKEN:-}" ]]; then
    return 0
  fi

  if [[ -n "${INFISICAL_API_URL:-}" ]]; then
    domain_arg=(--domain="$INFISICAL_API_URL")
  elif [[ -n "${INFISICAL_HOST:-}" ]]; then
    domain_arg=(--domain="${INFISICAL_HOST%/}/api")
  fi

  if ! infisical user --help 2>/dev/null | grep -Eq "^[[:space:]]+get[[:space:]]"; then
    log_status "Infisical CLI cannot export the logged-in user token; run infisical login when needed"
    return 1
  fi

  if token="$(infisical --silent user get token --plain "${domain_arg[@]}" </dev/null 2>/dev/null)" &&
    [[ "$token" =~ ^[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+$ ]]; then
    export INFISICAL_TOKEN="$token"
    return 0
  fi

  log_status "Infisical user token unavailable; run infisical login"
  return 1
}

infisical_load() {
  local env_slug="${1:?Infisical environment is required}"
  local secrets_path="${2:?Infisical path is required}"
  local secrets_file
  local domain_arg=()
  local project_id_arg=()
  local token_arg=()
  local dotenv_exports

  if [[ -n "${INFISICAL_API_URL:-}" ]]; then
    domain_arg=(--domain="$INFISICAL_API_URL")
  elif [[ -n "${INFISICAL_HOST:-}" ]]; then
    domain_arg=(--domain="${INFISICAL_HOST%/}/api")
  fi

  if [[ -n "${INFISICAL_PROJECT_ID:-}" ]]; then
    project_id_arg=(--projectId="$INFISICAL_PROJECT_ID")
  fi

  if [[ -n "${INFISICAL_TOKEN:-}" ]]; then
    token_arg=(--token="$INFISICAL_TOKEN")
  else
    log_status "Infisical secrets unavailable for ${env_slug}:${secrets_path}; run infisical login or set INFISICAL_TOKEN"
    return 0
  fi

  secrets_file="$(mktemp)"

  if infisical export \
    --silent \
    --env="$env_slug" \
    --path="$secrets_path" \
    --format=dotenv \
    "${domain_arg[@]}" \
    "${project_id_arg[@]}" \
    "${token_arg[@]}" \
    </dev/null >"$secrets_file"; then
    if dotenv_exports="$("$direnv" dotenv bash "$secrets_file")"; then
      eval "$dotenv_exports"
    else
      log_status "Infisical secrets unavailable for ${env_slug}:${secrets_path}; failed to parse dotenv export"
    fi
  else
    log_status "Infisical secrets unavailable for ${env_slug}:${secrets_path}; using existing environment"
  fi

  rm -f "$secrets_file"
}

if infisical_login_user_token; then
  infisical_load "$INFISICAL_ENV" /cv/content
  infisical_load "$INFISICAL_ENV" /cv/analytics
  infisical_load "$INFISICAL_ENV" /cv/application-registry
  infisical_load "$INFISICAL_ENV" /cv/deploy
  infisical_load "$INFISICAL_ENV" /cv/grafana
else
  log_status "Skipping Infisical secret export during direnv load"
fi

export PRIVATE_CONTENT_AUDIENCE_KEY="${PRIVATE_CONTENT_AUDIENCE_KEY:-cv-dev-private-audience-key-v1-minimum-32-bytes}"
